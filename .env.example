# STM Creator — Frontend environment variables
# Copy this file to .env.local and fill in values for your local setup.
# NEVER commit .env.local or any file containing real credentials.

# Base URL of the STM Creator backend REST API (no trailing slash).
# Required. Omitting this causes the app to fall back to the hardcoded
# production cloud URL baked in at build time.
VITE_API_BASE_URL=http://localhost:3000

# Socket.IO server URL used for real-time collaboration.
# Optional — defaults to VITE_API_BASE_URL when not set.
# Only needed if the WebSocket server runs on a different host/port than the REST API.
VITE_COLLAB_URL=http://localhost:3000

# Name of the default STM model loaded by the demo dataset loader.
# Optional — only relevant when running the bundled BMRG Rainforests demo dataset.
VITE_MODEL_NAME=BMRG Rainforests
